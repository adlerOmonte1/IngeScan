# =====================================================
# IngeScan - Variables de entorno
# Copia este archivo a `.env` y completa los valores.
# NUNCA subas el archivo `.env` real al repositorio.
# =====================================================

# Clave secreta de Flask (usa: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=cambia-esto-en-produccion

# Entorno: development | production
FLASK_ENV=development
FLASK_DEBUG=0

# Puerto en el que escucha la app (la nube suele inyectarlo automáticamente)
PORT=5000

# Credenciales de Nexar (Octopart): https://nexar.com/api
NEXAR_CLIENT_ID=2ec98ebb-9c17-4128-b28a-35e95a4f338c
NEXAR_CLIENT_SECRET=V-9IAEDOARvKAa3s57QeVy1NIbfL-lbZoXr3

# Umbral mínimo de confianza para aceptar una detección (0.0 - 1.0)
CONFIDENCE_THRESHOLD=0.80

# Ruta del modelo YOLO (default: ./best.pt)
MODEL_PATH=best.pt

# Ruta del archivo SQLite (default: ./usuarios.db)
DATABASE_PATH=usuarios.db

# Nivel de logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
